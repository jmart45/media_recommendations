# Required: powers the chat agent. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: enables posters, descriptions, and ratings on the Browse page.
# Get a free key at https://www.themoviedb.org/settings/api
# (either the "API Key" or the "API Read Access Token" works)
TMDB_API_KEY=your-api-key-here
